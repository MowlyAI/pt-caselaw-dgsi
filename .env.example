# OpenRouter API
OPENROUTER_API_KEY=

# Supabase - pt-dgsi project
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# Direct Postgres connection (used by the search API for HNSW + FTS).
# Use the Supabase session pooler host (port 5432).
SUPABASE_DB_HOST=aws-0-eu-west-1.pooler.supabase.com
SUPABASE_DB_PORT=5432
SUPABASE_DB_USER=postgres.unorogsjlkimrehyndzs
SUPABASE_DB_PASSWORD=
SUPABASE_DB_NAME=postgres

# Models
LLM_MODEL=google/gemini-3.1-flash-lite-preview
EMBEDDING_MODEL=qwen/qwen3-embedding-8b
EMBEDDING_DIMENSION=1024

# Scraper settings
SCRAPER_CONCURRENCY=15
SCRAPER_REQUEST_DELAY=0.2

# Extractor settings
EXTRACTOR_CONCURRENCY=20

# Embedder settings
EMBEDDER_CONCURRENCY=20
